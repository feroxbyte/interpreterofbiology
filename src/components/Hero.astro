---
import { Image } from "astro:assets";
import BioScatter from "./BioScatter.astro";
import Sticker from "./Sticker.astro";
import { BOOKING_URL } from "../config";
import heroImg from "../assets/hero.png";
---

<section
  id="top"
  class="relative overflow-hidden bg-butter border-b-2 border-ink"
>
  <BioScatter color="text-burg-deep" opacity={0.2} variant="lush" />
  <div class="relative mx-auto max-w-6xl px-5 py-24 md:py-32">
    <div
      class="grid items-center gap-12 lg:grid-cols-[1.05fr_0.95fr] lg:gap-12"
    >
      <!-- Text column -->
      <div>
        <p
          class="inline-flex items-center gap-2 mb-3 font-mono uppercase tracking-[0.14em] sm:tracking-[0.18em] text-burg-deep bg-paper border-2 border-ink rounded-full px-3 py-1.5 sm:px-4 text-[clamp(0.625rem,2.6vw,0.75rem)]"
        >
          <span class="inline-block h-2 w-2 rounded-full bg-primary"></span>
          Genetic & epigenetic optimization
        </p>
        <h1
          class="font-serif tracking-tight text-burg-deep leading-[0.95] text-5xl md:text-7xl"
        >
          Stop guessing. Start <span class="italic">coding</span> your health from
          your cellular blueprint.
        </h1>
        <p
          class="font-sans font-semibold text-ink text-xl md:text-2xl mt-8 max-w-xl"
        >
          We translate your genetic data into an elite, data-driven protocol. No
          medical suppression. Just molecular optimization designed for your
          unique DNA.
        </p>
        <div class="mt-10 flex flex-wrap items-center gap-4">
          <a
            href={BOOKING_URL}
            class="font-sans font-bold text-white bg-primary border-2 border-ink rounded-full px-4 md:px-7 py-3 whitespace-nowrap text-[clamp(0.75rem,3.2vw,1.125rem)] shadow-[6px_6px_0_var(--color-ink)] hover:translate-x-[-2px] hover:translate-y-[-2px] hover:shadow-[8px_8px_0_var(--color-ink)] transition-all"
          >
            Apply for your Cellular Blueprint
          </a>
          <Sticker bg="bg-neon-lime" rotate={-2}
            >no generic advice. ever.</Sticker
          >
        </div>
      </div>

      <!-- Illustration column (bordered showcase card) -->
      <div class="lg:justify-self-end">
        <div
          class="relative mx-auto w-full max-w-sm lg:max-w-none border-2 border-ink rounded-2xl overflow-hidden bg-butter shadow-[10px_10px_0_var(--color-ink)]"
        >
          <Image
            src={heroImg}
            alt="A scientist at a microscope surrounded by DNA, chromosomes, cells and lab flasks, captioned 'wtf is that?! — the interpreter of biology'."
            widths={[400, 600, 896]}
            sizes="(max-width: 1024px) 90vw, 480px"
            loading="eager"
            fetchpriority="high"
            class="block w-full h-auto"
          />
        </div>
      </div>
    </div>
  </div>
</section>
