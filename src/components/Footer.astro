---
import { BOOKING_URL } from "../config";
const taglines = [
  "biological systems · translated",
  "your cellular blueprint, decoded.",
  "optimization with genetic certainty.",
];
const disclaimer =
  "Pelin Çeyrekbaşıoğlu, BSc, holds a Bachelor of Science degree in Cell and Molecular Biology from the University of South Florida and is a Certified dnalife® Practitioner. She is not a licensed medical doctor, registered dietitian, or licensed nutritionist in the State of Florida. The Cellular Blueprint Program does not provide medical nutrition therapy, diagnostics, or clinical medical treatments. All insights, materials, and consultations are strictly for informational, educational, and performance optimization purposes.";
---

<footer class="bg-ink text-paper">
  <div class="mx-auto max-w-6xl px-5 py-16">
    <div
      class="flex flex-col gap-8 md:flex-row md:items-end md:justify-between"
    >
      <div>
        <span class="font-serif italic text-2xl text-paper"
          >the interpreter</span
        >
        <span class="block h-1 w-32 bg-neon-lime mt-1"></span>
        <p class="font-mono text-sm text-paper/70 mt-4 max-w-xs">
          The Cellular Blueprint Program — genetic &amp; epigenetic
          optimization, translated into an actionable protocol.
        </p>
      </div>
      <div class="font-mono text-sm text-paper/70 space-y-1">
        {taglines.map((t) => <p>{t}</p>)}
        <a
          href={BOOKING_URL}
          class="inline-block mt-3 text-neon-lime hover:underline"
          >Book your initial consultation →</a
        >
      </div>
    </div>
    <div class="mt-12 border-t border-paper/15 pt-6">
      <p
        class="font-sans font-bold text-paper/60 text-xs uppercase tracking-wide"
      >
        ⚠️ Professional &amp; legal disclaimer
      </p>
      <p class="font-mono text-xs text-paper/65 mt-3 leading-relaxed max-w-4xl">
        {disclaimer}
      </p>
      <p class="font-mono text-xs text-paper/55 mt-4">
        © 2026 The Interpreter of Biology · The Cellular Blueprint Program
      </p>
    </div>
  </div>
</footer>
