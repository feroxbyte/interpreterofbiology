---
import BioScatter from "./BioScatter.astro";
import { BOOKING_URL } from "../config";
const includes = [
  "dnalife® lab kit, shipped to you",
  "Two live virtual consultations",
  "Custom multi-page protocol",
  "30 days of concierge support",
];
---

<section
  id="request"
  class="relative overflow-hidden bg-butter text-ink border-y-2 border-ink"
>
  <BioScatter color="text-burg-deep" opacity={0.12} />
  <div class="relative mx-auto max-w-3xl px-5 py-28 text-center">
    <p class="font-mono text-sm text-burg-deep">
      the ultimate user manual for your biology
    </p>
    <h2
      class="font-serif tracking-tight text-burg-deep text-4xl md:text-6xl mt-4"
    >
      Secure your <span class="italic">Cellular Blueprint</span> today.
    </h2>
    <p class="font-sans font-semibold text-ink text-lg mt-6">
      Stop experimenting with your health. Start optimizing with genetic
      certainty.
    </p>
    <div
      class="mt-8 inline-block bg-paper border-2 border-ink rounded-xl px-8 py-5 shadow-[6px_6px_0_var(--color-ink)]"
    >
      <p class="font-mono text-xs uppercase tracking-[0.18em] text-ink/60">
        Program investment
      </p>
      <p
        class="font-sans font-extrabold text-ink text-3xl md:text-4xl mt-1 leading-none"
      >
        $950 <span class="text-ink/35">–</span> $2000
      </p>
      <p
        class="font-mono text-[0.7rem] uppercase tracking-[0.16em] text-ink/45 mt-3"
      >
        All-inclusive
      </p>
      <ul
        class="mt-3 grid grid-cols-1 gap-y-1.5 text-left sm:grid-cols-2 sm:gap-x-7"
      >
        {
          includes.map((it) => (
            <li class="flex items-baseline gap-2 font-mono text-sm text-ink/80">
              <span class="text-primary font-bold">✓</span>
              {it}
            </li>
          ))
        }
      </ul>
    </div>
    <div class="mt-10">
      <a
        href={BOOKING_URL}
        class="inline-block font-sans font-bold text-lg text-white bg-primary border-2 border-ink rounded-full px-8 py-4 shadow-[6px_6px_0_var(--color-ink)] hover:translate-x-[-2px] hover:translate-y-[-2px] hover:shadow-[9px_9px_0_var(--color-ink)] transition-all"
      >
        Book your initial consultation
      </a>
    </div>
  </div>
</section>
