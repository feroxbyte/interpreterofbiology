---
interface Props {
  class?: string;
}
const { class: className = "" } = Astro.props;
---

<svg
  viewBox="0 0 64 64"
  fill="none"
  stroke="currentColor"
  stroke-width="2"
  stroke-linecap="round"
  class={className}
  aria-hidden="true"
>
  <!-- bonds -->
  <line x1="32" y1="14" x2="16" y2="36"></line>
  <line x1="32" y1="14" x2="48" y2="36"></line>
  <line x1="16" y1="36" x2="32" y2="52"></line>
  <line x1="48" y1="36" x2="32" y2="52"></line>
  <!-- atoms -->
  <circle cx="32" cy="14" r="5"></circle>
  <circle cx="16" cy="36" r="5"></circle>
  <circle cx="48" cy="36" r="5"></circle>
  <circle cx="32" cy="52" r="5"></circle>
  <circle cx="32" cy="33" r="2" fill="currentColor" stroke="none"></circle>
</svg>
