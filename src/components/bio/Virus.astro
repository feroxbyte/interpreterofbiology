---
interface Props {
  class?: string;
}
const { class: className = "" } = Astro.props;
---

<svg
  viewBox="0 0 64 64"
  fill="none"
  stroke="currentColor"
  stroke-width="2"
  stroke-linecap="round"
  class={className}
  aria-hidden="true"
>
  <circle cx="32" cy="32" r="16"></circle>
  <g>
    <line x1="32" y1="16" x2="32" y2="4"></line><line
      x1="32"
      y1="48"
      x2="32"
      y2="60"></line>
    <line x1="16" y1="32" x2="4" y2="32"></line><line
      x1="48"
      y1="32"
      x2="60"
      y2="32"></line>
    <line x1="20.7" y1="20.7" x2="12.2" y2="12.2"></line><line
      x1="43.3"
      y1="43.3"
      x2="51.8"
      y2="51.8"></line>
    <line x1="43.3" y1="20.7" x2="51.8" y2="12.2"></line><line
      x1="20.7"
      y1="43.3"
      x2="12.2"
      y2="51.8"></line>
  </g>
  <circle cx="32" cy="4" r="2.5" fill="currentColor" stroke="none"></circle>
  <circle cx="32" cy="60" r="2.5" fill="currentColor" stroke="none"></circle>
  <circle cx="4" cy="32" r="2.5" fill="currentColor" stroke="none"></circle>
  <circle cx="60" cy="32" r="2.5" fill="currentColor" stroke="none"></circle>
</svg>
