---
import { BOOKING_URL } from "../config";
const links = [
  { href: "#problem", label: "The problem" },
  { href: "#analyst", label: "The science" },
  { href: "#workflow", label: "The program" },
];
---

<header
  class="sticky top-0 z-50 bg-paper/90 backdrop-blur border-b-2 border-ink"
>
  <nav
    class="mx-auto flex max-w-6xl items-center justify-between px-5 py-3"
    aria-label="Main"
  >
    <a
      href="#top"
      class="group block shrink-0 leading-none"
      aria-label="interpreter of biology — home"
    >
      {
        /* One wordmark at every width. clamp() shrinks it on narrow phones and
          nowrap keeps it on a single line — no separate monogram. */
      }
      <span
        class="block font-serif italic text-ink whitespace-nowrap text-[clamp(0.95rem,4.2vw,1.25rem)] mb-1"
      >
        interpreter of biology
      </span>
      {
        /* Signature underbar — spans the full text width; electric blue clears
          WCAG non-text 3:1 on both paper and butter (neon-lime did not). */
      }
      <span class="block h-1 w-full bg-primary"></span>
    </a>
    <div class="hidden items-center gap-7 md:flex">
      {
        links.map((l) => (
          <a href={l.href} class="font-mono text-sm text-ink/80 hover:text-ink">
            {l.label}
          </a>
        ))
      }
    </div>
    <a
      href={BOOKING_URL}
      class="font-sans font-bold text-sm text-white bg-primary border-2 border-ink rounded-full px-4 py-2 whitespace-nowrap hover:-translate-y-0.5 transition-transform"
    >
      <span class="md:hidden">Apply</span>
      <span class="hidden md:inline">Apply for your blueprint</span>
    </a>
  </nav>
</header>
