---
import "../styles/theme.css";
import { SITE_URL, OG_IMAGE, BOOKING_URL } from "../config";

interface Props {
  title?: string;
  description?: string;
}
const {
  title = "The Interpreter of Biology — The Cellular Blueprint Program",
  description = "Translate your genetic data into an elite, data-driven protocol. Methylation, detoxification, inflammation, and mitochondrial optimization — designed for your unique DNA.",
} = Astro.props;

// Canonical URL for this page (Astro.site comes from astro.config `site`).
const canonical = new URL(Astro.url.pathname, Astro.site ?? SITE_URL).href;

// Structured data — a service run by a named expert. Deliberately NON-medical
// schema types (Organization/Service/Person), matching the legal disclaimer.
const orgId = `${SITE_URL}/#organization`;
const personId = `${SITE_URL}/#pelin`;
const serviceId = `${SITE_URL}/#service`;
const websiteId = `${SITE_URL}/#website`;
const jsonLd = {
  "@context": "https://schema.org",
  "@graph": [
    {
      "@type": "Organization",
      "@id": orgId,
      name: "The Interpreter of Biology",
      url: SITE_URL,
      logo: `${SITE_URL}/favicon.svg`,
      image: OG_IMAGE,
      description:
        "Genetic & epigenetic optimization — translating your DNA into a data-driven, personalized protocol.",
      founder: { "@id": personId },
      knowsAbout: [
        "Genetic optimization",
        "Epigenetics",
        "Methylation",
        "Detoxification",
        "Inflammation",
        "Mitochondrial health",
        "Nutrigenomics",
      ],
    },
    {
      "@type": "Person",
      "@id": personId,
      name: "Pelin Çeyrekbaşıoğlu",
      jobTitle: "Genetic & Epigenetic Optimization Scientist",
      worksFor: { "@id": orgId },
      alumniOf: {
        "@type": "CollegeOrUniversity",
        name: "University of South Florida",
      },
      hasCredential: [
        {
          "@type": "EducationalOccupationalCredential",
          credentialCategory: "degree",
          educationalLevel: "Bachelor of Science",
          about: "Cell & Molecular Biology",
        },
        {
          "@type": "EducationalOccupationalCredential",
          credentialCategory: "certification",
          name: "dnalife® Certified Practitioner",
        },
      ],
    },
    {
      "@type": "Service",
      "@id": serviceId,
      name: "The Cellular Blueprint Program",
      serviceType: "Genetic & epigenetic optimization consultation",
      provider: { "@id": orgId },
      description:
        "A premium, end-to-end genetic optimization program: a dnalife® lab kit, two live virtual consultations, a custom multi-page protocol, and 30 days of concierge support.",
      areaServed: [
        { "@type": "Country", name: "United States" },
        { "@type": "Place", name: "European Union" },
      ],
      offers: {
        "@type": "AggregateOffer",
        priceCurrency: "USD",
        lowPrice: 950,
        highPrice: 1200,
        offerCount: 1,
        availability: "https://schema.org/InStock",
        url: BOOKING_URL,
      },
    },
    {
      "@type": "WebSite",
      "@id": websiteId,
      url: SITE_URL,
      name: "The Interpreter of Biology",
      publisher: { "@id": orgId },
      inLanguage: "en",
    },
    {
      "@type": "WebPage",
      "@id": `${canonical}#webpage`,
      url: canonical,
      name: title,
      description,
      isPartOf: { "@id": websiteId },
      about: { "@id": serviceId },
      primaryImageOfPage: OG_IMAGE,
      inLanguage: "en",
    },
  ],
};
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <link rel="icon" type="image/png" sizes="32x32" href="/favicon-32.png" />
    <link rel="icon" href="/favicon.ico" sizes="32x32" />
    <link rel="apple-touch-icon" href="/apple-touch-icon.png" />
    <link rel="manifest" href="/site.webmanifest" />
    <meta name="generator" content={Astro.generator} />

    <!-- Primary meta -->
    <title>{title}</title>
    <meta name="description" content={description} />
    <meta name="author" content="Pelin Çeyrekbaşıoğlu" />
    <meta name="robots" content="index, follow, max-image-preview:large" />
    <meta name="theme-color" content="#fdff85" />
    <link rel="canonical" href={canonical} />
    <link rel="sitemap" href="/sitemap-index.xml" />

    <!-- Open Graph -->
    <meta property="og:type" content="website" />
    <meta property="og:site_name" content="The Interpreter of Biology" />
    <meta property="og:locale" content="en_US" />
    <meta property="og:url" content={canonical} />
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:image" content={OG_IMAGE} />
    <meta property="og:image:type" content="image/jpeg" />
    <meta property="og:image:width" content="1200" />
    <meta property="og:image:height" content="630" />
    <meta
      property="og:image:alt"
      content="The Interpreter of Biology — The Cellular Blueprint Program"
    />

    <!-- Twitter -->
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content={title} />
    <meta name="twitter:description" content={description} />
    <meta name="twitter:image" content={OG_IMAGE} />
    <meta
      name="twitter:image:alt"
      content="The Interpreter of Biology — The Cellular Blueprint Program"
    />

    <!-- Structured data -->
    <script is:inline type="application/ld+json" set:html={JSON.stringify(jsonLd)} />

    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link
      href="https://fonts.googleapis.com/css2?family=Playfair+Display:ital,wght@0,400;0,700;0,900;1,400;1,700;1,900&family=DM+Mono:ital,wght@0,300;0,400;0,500;1,300;1,400&family=Syne:wght@400;600;700;800&display=swap"
      rel="stylesheet"
    />
  </head>
  <body>
    <a
      href="#top"
      class="sr-only focus:not-sr-only focus:fixed focus:z-[100] focus:top-3 focus:left-3 focus:rounded-full focus:border-2 focus:border-ink focus:bg-ink focus:px-4 focus:py-2 focus:font-sans focus:text-sm focus:font-bold focus:text-paper"
    >
      Skip to content
    </a>
    <slot />
    <script>
      import "../scripts/reveal.ts";
    </script>
  </body>
</html>
